{
  "rewrites": [
    {
      "source": "/",
      "destination": "/onlifit.html"
    }
  ],
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Upgrade-Insecure-Requests",
          "value": "1"
        }
      ]
    }
  ]
}
